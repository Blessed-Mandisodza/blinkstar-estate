{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://blinkstar-estate-backend-git-main-blinkstar-techs-projects.vercel.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://blinkstar-estate-backend-git-main-blinkstar-techs-projects.vercel.app/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
